{
  "manifest_version": 3,
  "name": "カスタム・サイト翻訳プロ",
  "version": "1.2",
  "description": "サイトごとに特定の単語やフレーズを自由に置換します。",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dictionary.js", "content.js"],
      "run_at": "document_end"
    }
  ]
}
